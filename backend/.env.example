# ===========================
# DocuMind 2.0 — Environment
# ===========================

# LLM Providers
GROQ_API_KEY=your_groq_key
ANTHROPIC_API_KEY=your_anthropic_key

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./documind.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Authentication
SECRET_KEY=your-very-long-random-secret-key-minimum-32-chars-change-this
ACCESS_TOKEN_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_DAYS=7

# Observability (LangSmith)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=documind-production

# Storage
UPLOAD_DIR=/uploads
MAX_UPLOAD_SIZE_MB=50

# Evaluation
RAGAS_EVAL_ENABLED=true
RAGAS_FAITHFULNESS_THRESHOLD=0.8

# Embedding Model
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Cross Encoder
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# Default LLM
DEFAULT_LLM_MODEL=llama-3.1-8b-instant
DEFAULT_LLM_PROVIDER=groq
